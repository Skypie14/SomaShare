@page "/Dashboard"
@rendermode InteractiveServer
@using SomaShare.Components.Model
@using SomaShare.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore
@inject UserSession session

@inject NavigationManager Navigation

<h3>Welcome to the Dashboard</h3>
    
@if (session.CurrentUserRoleId == 1)
{
    <button @onclick="GoToBrowseWants">Browse Wants</button>
    <button @onclick="GoToCreateListing">Create Listing</button>
    <button @onclick="GoToManageListing">Manage Listing</button>
    <button @onclick="GoToOffers">View Offers</button>
}
else if (session.CurrentUserRoleId == 2)
{
    <button @onclick="GoToBrowseListings">Browse Listings</button>
    <button @onclick="GoToCreateWants">Create Wants</button>
    <button @onclick="GoToManageWants">Manage Wants</button>
    <button @onclick="GoToOffers">View Offers</button>
}
else if (session.CurrentUserRoleId == 3)
{
    <button @onclick="GoToBrowseWants">Browse Wants</button>
    <button @onclick="GoToCreateListing">Create Listing</button>
    <button @onclick="GoToManageListing">Manage Listing</button>
    <button @onclick="GoToOffers">View Offers</button>
    <button @onclick="GoToBrowseListings">Browse Listings</button>
    <button @onclick="GoToCreateWants">Create Wants</button>
    <button @onclick="GoToManageWants">Manage Wants</button>
    <button @onclick="GoToOffers">View Offers</button>
}
else if (session.CurrentUser != null){
    <p> Smth wrong</p>
}
else
{
    Navigation.NavigateTo("/");
}

@code {

    private void GoToBrowseWants()
    {
        Navigation.NavigateTo("/browsewants");
    }

    private void GoToCreateListing()
    {
        Navigation.NavigateTo("/createlisting");
    }

    private void GoToManageListing()
    {
        Navigation.NavigateTo("/managelisting");
    }

    private void GoToOffers()
    {
        Navigation.NavigateTo("/offers");
    }

    private void GoToBrowseListings()
    {
        Navigation.NavigateTo("/browselistings");
    }

    private void GoToCreateWants()
    {
        Navigation.NavigateTo("/createwants");
    }

    private void GoToManageWants()
    {
        Navigation.NavigateTo("/managewants");
    }

}