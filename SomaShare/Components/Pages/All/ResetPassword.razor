@page "/reset-password"
@using Microsoft.AspNetCore.Identity
@using SomaShare.Components.Model
@rendermode InteractiveServer

@inject UserManager<User> UserManager
@inject NavigationManager NavManager

<h3>Reset Password</h3>

@if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(code))
{
    <div> Invalid password reset link.</div>
}
else
{
    <div class="form-group">
        <label>New Password:</label>
        <input type="password" @bind="password" placeholder="Enter new password" />
        <p>At least 8 characters, uppercase, lowercase, number, and special character</p>
    </div>

    <div class="form-group">
        <label>Confirm Password:</label>
        <input type="password" @bind="confirmPassword"  placeholder="Confirm new password" />
    </div>

    <button class="btn btn-primary" @onclick="ResetPasswordAsync">Reset Password</button>
    <button class="btn btn-secondary" @onclick="GoBack">Cancel</button>
}

@if (!string.IsNullOrEmpty(message))
{
    <div role="alert">
        @message
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public string? email { get; set; }

    [SupplyParameterFromQuery]
    public string? code { get; set; }

    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string message = string.Empty;
    private bool isError = false;

    private async Task ResetPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(password) || password.Length < 8)
        {
            message = "Password must be at least 8 characters long.";
            isError = true;
            return;
        }

        if (password != confirmPassword)
        {
            message = "Passwords do not match.";
            isError = true;
            return;
        }

        try
        {
            var user = await UserManager.FindByEmailAsync(email);
            if (user == null)
            {
                message = "Invalid password reset request.";
                isError = true;
                return;
            }

            var result = await UserManager.ResetPasswordAsync(user, code, password);

            if (result.Succeeded)
            {
                message = "Password reset successful! Redirecting to login...";
                isError = false;
                await Task.Delay(2000);
                NavManager.NavigateTo("/");
            }
            else
            {
                var errors = string.Join(", ", result.Errors.Select(e => e.Description));
                message = $"Password reset failed: {errors}";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            message = $"An error occurred: {ex.Message}";
            isError = true;
        }
    }

    private void GoBack()
    {
        NavManager.NavigateTo("/");
    }
}
