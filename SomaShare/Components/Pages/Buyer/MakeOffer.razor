@page "/make-offer/{listingId:int}"
@rendermode InteractiveServer
@using SomaShare.Components.Model
@using SomaShare.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore

@inject IOfferService OfferService
@inject IListingService ListingService
@inject NavigationManager NavManager
@inject UserSession session

<PageTitle>Make an Offer - SomaShare</PageTitle>

    <div class="row">
        <div>
            @if (loading)
            {
            }
            else if (listing == null)
            {
                <div>
                    <h4>Listing Not Found</h4>
                    <p>This listing does not exist.</p>
                    <button class="btn btn-primary" @onclick="GoBack">Go Back</button>
                </div>
            }
            else if (hasAlreadyMadeOffer)
            {
                <div>
                    <h4>Already Made an Offer</h4>
                    <p>You have already made an offer on this listing. Please wait for the seller's response.</p>
                    <button class="btn btn-primary" @onclick="GoBack">Go Back</button>
                </div>
            }
            else
            {
                <div class="card">
                    <div>
                        <h3>Make an Offer</h3>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div>
                                @errorMessage
                                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                            </div>
                        }

                        <!-- Listing Details -->
                        <div>
                            <div>
                                <h5>Book Details</h5>
                                <p><strong>Title:</strong> @listing.Textbook.Title</p>
                                <p><strong>Author:</strong> @listing.Textbook.Author</p>
                                @if (!string.IsNullOrEmpty(listing.Textbook.ISBN))
                                {
                                    <p><strong>ISBN:</strong> @listing.Textbook.ISBN</p>
                                }
                                <p><strong>Condition:</strong> @listing.Condition</p>
                            </div>
                            <div>
                                <h5>Listing Details</h5>
                                <p><strong>Asking Price:</strong> <p>$@listing.Price.ToString("F2")</p></p>
                                @if (!string.IsNullOrEmpty(listing.CampusLocation))
                                {
                                    <p><strong>Campus:</strong> @listing.CampusLocation</p>
                                }
                                <p><strong>Seller:</strong> @listing.User.First_Name @listing.User.Last_Name</p>
                                <p><strong>Listed:</strong> @listing.Date_Posted.ToString("MMM dd, yyyy")</p>
                            </div>
                        </div>

                        <!-- Offer Form -->
            <form @onsubmit="SubmitOffer">
             <div>
                 <label for="offerPrice"><strong>Your Offer Price *</strong></label>
                 <div >
                    <input type="number" id="offerPrice" placeholder="0.00" step="0.01" min="0.01" max="10000"@bind="offer.OfferedPrice" required />
                 </div>
                 <p>
                     @if (offer.OfferedPrice > 0)
                     {
                         var difference = listing.Price - offer.OfferedPrice;
                         var percentage = (difference / listing.Price) * 100;
                         @if (difference > 0)
                         {
                             <text>You are offering <strong>$@difference.ToString("F2")</strong> (<strong>@percentage.ToString("F1")%</strong>) less than asking price</text>
                         }
                         else if (difference < 0)
                         {
                             <text>You are offering <strong>$@Math.Abs(difference).ToString("F2")</strong> (<strong>@Math.Abs(percentage).ToString("F1")%</strong>) more than asking price</text>
                         }
                         else
                         {
                             <text>You are offering the asking price</text>
                         }
                     }
                 </p>
             </div>

             <div>
                 <label for="message" >Message (Optional)</label>
                 <textarea  id="message" rows="4" placeholder="message here" @bind="offer.Message" maxlength="500"></textarea>
                 <p>
                     @(offer.Message?.Length ?? 0) / 500 characters
                 </p>
             </div>
     
             <div>
                 <button type="button" class="btn btn-secondary" @onclick="GoBack">Cancel</button>
                 <button type="submit" class="btn btn-success" disabled="@(isSubmitting || offer.OfferedPrice <= 0)">
                     @if (isSubmitting)
                     {
                     }
                     else
                     {
                         <p>Submit Offer</p>
                     }
                 </button>
             </div>
         </form>
     </div>
                </div>
            }
        </div>
    </div>

@code {
    [Parameter]
    public int ListingId { get; set; }

    //store details
    private ListingAd listing;
    //create new offer object
    private Offer offer = new();
    
    //ui state variables
    private string errorMessage = string.Empty;
    private bool loading = true;
    private bool isSubmitting = false;
    private bool hasAlreadyMadeOffer = false;


    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Check if user is logged in
            if (session?.CurrentUserRoleId == null || session.CurrentUserRoleId != 3 && session.CurrentUserRoleId != 1) // Ensure user is a buyer or Admin
            {
                NavManager.NavigateTo("/");
                return;
            }

            // Load listing 
            listing = await ListingService.GetListingAsync(ListingId);

            if (listing == null) //if does not exist
            {
                errorMessage = "Listing not found";
                loading = false;
                return;
            }

            // prevent buyer from making offer on own listing
            if (listing.User_ID == session.CurrentUser.Id)
            {
                errorMessage = "You cannot make an offer on your own listing";
                loading = false;
                return;
            }

            // Check if user already made an offer
            hasAlreadyMadeOffer = await OfferService.HasUserMadeOfferAsync(ListingId, session.CurrentUser.Id);

            //if no offer exists, initialize one
            if (!hasAlreadyMadeOffer)
            {
                // Initialize offer
                offer.ListingAd_ID = ListingId;  //link to listing
                offer.Buyer_ID = session.CurrentUser.Id; //current user is buyer
                offer.Seller_ID = listing.User_ID;  //current owner is seller
            }
        }
        catch (Exception ex)
        {//handle rrors during loading
            errorMessage = $"Error loading page: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    //handle offer submit
    private async Task SubmitOffer()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;

            // Validate max price limit (> 0)
            if (offer.OfferedPrice <= 0)
            {
                errorMessage = "Offer price must be greater than $0.00";
                return;
            }

            if (offer.OfferedPrice > 10000)
            {
                errorMessage = "Offer price cannot exceed $10,000";
                return;
            }

            // Check again if already made offer (prevent double submission)
            if (await OfferService.HasUserMadeOfferAsync(ListingId, session.CurrentUser.Id))
            {
                errorMessage = "You have already made an offer on this listing";
                return;
            }

            // Create offer/service
            await OfferService.CreateOfferAsync(offer);

            // Redirect to listings
            NavManager.NavigateTo("/browselistings?success=Offer submitted successfully!");
        }
        catch (Exception ex)
        {
            //error handling during submission
            errorMessage = $"Error submitting offer: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    //nav back to listings
    private void GoBack()
    {
        NavManager.NavigateTo("/browselistings");
    }
}
