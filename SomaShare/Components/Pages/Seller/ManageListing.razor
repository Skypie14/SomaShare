@page "/listings"
@rendermode InteractiveServer
@using SomaShare.Components.Model
@using SomaShare.Services
@using Microsoft.AspNetCore.Components

@inject IListingService ListingService
@inject NavigationManager NavManager
@inject UserSession session

<PageTitle>Manage Listings - SomaShare</PageTitle>

<div>
   <h2>My Listings</h2>
</div>
<div>
  <button @onclick="CreateNewListing"> Create New Listing </button>
</div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div>
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div>
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (loading)
    {
    }
    else if (listings == null || listings.Count == 0)
    {
        <div >
            <h4>No Listings Yet</h4>
            <p>You don't have any listings yet. Click the button to create your first listing</p>
            <button class="btn btn-primary" @onclick="CreateNewListing">Create Listing</button>
        </div>
    }
    else
    {
        <div>
            @foreach (var listing in listings)
            {
              
                    <div >
                      

                        <div class="card-body">
                            <div>
                                <div>
                                    <h5 >@listing.Textbook.Title</h5>
                                    <p>by @listing.Textbook.Author</p>
                                </div>
                                <span class="badge @(listing.IsActive ? "bg-success" : "bg-secondary")">
                                    @(listing.IsActive ? "Active" : "Inactive")
                                </span>
                            </div>

                            <div>
                                @if (!string.IsNullOrEmpty(listing.Textbook.ISBN))
                                {
                                    <p>
                                        <strong>ISBN:</strong> @listing.Textbook.ISBN
                                    </p>
                                }

                                @if (!string.IsNullOrEmpty(listing.Textbook.Version))
                                {
                                    <p >
                                        <strong>Edition:</strong> @listing.Textbook.Version
                                    </p>
                                }

                                <p>
                                    <strong>Condition:</strong> @listing.Condition
                                </p>

                                @if (!string.IsNullOrEmpty(listing.CampusLocation))
                                {
                                    <small>
                                        <strong>Location:</strong> @listing.CampusLocation
                                    </small>
                                }

                                <small>
                                    <strong>Posted:</strong> @listing.Date_Posted.ToString("MMM dd, yyyy")
                                </small>

                                @if (listing.Date_Updated.HasValue)
                                {
                                    <small>
                                        <strong>Updated:</strong> @listing.Date_Updated.Value.ToString("MMM dd, yyyy")
                                    </small>
                                }
                            </div>

                            <div >
                                <h4 >$@listing.Price.ToString("F2")</h4>
                            </div>

                            @if (listing.Offers != null && listing.Offers.Count > 0)
                            {
                                <div >
                                    <small><strong>@listing.Offers.Count</strong> offer@(listing.Offers.Count != 1 ? "s" : "")</small>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(listing.Description))
                            {
                                <p >
                                    @if (listing.Description.Length > 100)
                                    {
                                        <text>@listing.Description.Substring(0, 100)...</text>
                                    }
                                    else
                                    {
                                        <text>@listing.Description</text>
                                    }
                                </p>
                            }
                        </div>

                   
                   <div >
                     <button @onclick="() => EditListing(listing.ListingAd_ID)"> Edit </button>
                      <button @onclick="() => DeleteListing(listing.ListingAd_ID)"> Delete </button>
                       @if (listing.Offers != null && listing.Offers.Count > 0)
                         {
                           <button @onclick="() => ViewOffers(listing.ListingAd_ID)"> Offers </button>
                         }
                     </div>
                 
              </div>
       
            }
        </div>
    }


<!-- Delete Confirmation Modal -->
@if (showDeleteConfirm)
{

  <div>
    <h5 >Delete Listing</h5>
    <button type="button" class="btn-close" @onclick="() => showDeleteConfirm = false"></button>
  </div>
  <div>
   <p>Are you sure you want to delete this listing?</p>
   <p >This action cannot be undone.</p>
  </div>

  <div>
   <button type="button" @onclick="() => showDeleteConfirm = false">Cancel</button>
   <button type="button" @onclick="ConfirmDelete" disabled="@isDeleting">
      @if (isDeleting)
        {
         }
         else
           {
            <span>Delete</span>
           }
    </button>
  </div>

}

@code {
    private List<ListingAd> listings;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool loading = true;
    private bool isDeleting = false;
    private bool showDeleteConfirm = false;
    private int listingToDeleteId = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
             // Check if user is logged in and is a seller
            if (session?.CurrentUser == null || !session.IsSeller)
            {
                NavManager.NavigateTo("/dashboard");
                return;
            }

            // Load user's listings
            await LoadListings();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading listings: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadListings()
    {
        try
        {
            listings = await ListingService.GetUserListingsAsync(session.CurrentUser.Id);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error retrieving listings: {ex.Message}";
        }
    }

    private void CreateNewListing()
    {
        NavManager.NavigateTo("/createlistings");
    }

    private void EditListing(int listingId)
    {
        NavManager.NavigateTo($"/edit-listing/{listingId}");
    }

    private void ViewOffers(int listingId)
    {
        // This will navigate to offers page when created
        NavManager.NavigateTo($"/offers/{listingId}");
    }

    //trigger delete confirmation
    private void DeleteListing(int listingId)
    {
        listingToDeleteId = listingId; //store id
        showDeleteConfirm = true; //show confirmation ui
    }

    private async Task ConfirmDelete()
    {
        try
        {
            isDeleting = true;
            errorMessage = string.Empty;

            //Call service to delete listing
            await ListingService.DeleteListingAsync(listingToDeleteId);

            successMessage = "Listing deleted successfully!";
            showDeleteConfirm = false;

            // Reload listings
            await LoadListings();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting listing: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }
}