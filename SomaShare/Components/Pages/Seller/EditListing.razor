@page "/editlisting/{listingId:int}"
@rendermode InteractiveServer
@using SomaShare.Components.Model
@using SomaShare.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore

@inject IListingService ListingService
@inject SomaContext Context
@inject NavigationManager NavManager
@inject UserSession session

<PageTitle>Edit Listing - SomaShare</PageTitle>

    <div >
        <div>
            @if (loading)
            {
             
            }
            else if (listing == null)
            {
                <div>
                    Listing not found or you don't have permission to edit this listing.
                </div>
                <button class="btn btn-secondary" @onclick="GoBack">Back to Listings</button>
            }
            else
            {
                <div class="card">
                    <h3>Edit Listing</h3>
       
                    <div>
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div role="alert">
                                @errorMessage
                                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div role="alert">
                                @successMessage
                                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
                            </div>
                        }

                        <form @onsubmit="SubmitForm">
                            <h5 >Textbook Information</h5>
                            <div>
                                <div>
                                    <label >Title</label>
                                    <input type="text" id="title" placeholder="Enter textbook title" @bind="listing.Textbook.Title" required />

                                </div>
                                <div >
                                    <label>Author </label>
                                    <input type="text" id="author" placeholder="Enter author name" @bind="listing.Textbook.Author" required />
                                </div>
                            </div>

                            <div>
                                <div >
                                    <label>ISBN</label>
                                    <input type="text" id="isbn" placeholder="Enter ISBN" @bind="listing.Textbook.ISBN" />

                                </div>
                                <div >
                                    <label>Edition/Version</label>
                                    <input type="text" id="version" placeholder="Edition/Version"
                                           @bind="listing.Textbook.Version" />

                                </div>
                            </div>

                            <div>
                                <label>Genre </label>
                                <select id="genre" @bind="listing.Textbook.Genre_ID" required>
                                    <option value="">-- Select a Genre --</option>
                                    @foreach (var genre in genres)
                                    {
                                        <option value="@genre.Genre_ID">@genre.Genre_Name</option>
                                    }
                                </select>
                            </div>

                            <div >
                                <label> Description</label>
                                <textarea  id="description" rows="3" placeholder="Enter textbook description" @bind="listing.Textbook.Description"></textarea>

                            </div>

                            <h5>Listing Details</h5>
                            <div>
                                <div >
                                    <label> Price </label>
                                    <input type="number"  id="price" placeholder="0.00" step="0.01" min="0.01" max="10000" @bind="listing.Price" required />
                                </div>

                                <div>
                                    <label for="condition">Condition *</label>
                                    <select id="condition" @bind="listing.Condition" required>
                                        <option value="">-- Select Condition --</option>
                                        <option value="Like New">Like New</option>
                                        <option value="Good">Good</option>
                                        <option value="Fair">Fair</option>
                                        <option value="Poor">Poor</option>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <label>Campus Location</label>
                                <input type="text" id="campus" placeholder="e.g., Main Campus, Downtown (optional)"
                                       @bind="listing.CampusLocation" />
                                
                            </div>

                           
                            <div>
                                <label>
                                    <input type="checkbox" @bind="listing.IsActive" />
                                    <p>Listing is Active</p>
                                </label>
                            </div>

                            <div>
                                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                    }
                                    else
                                    {
                                        <p>Save Changes</p>
                                    }
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

@code {
    [Parameter]
    public int ListingId { get; set; }

    private ListingAd listing;
    private List<Genre> genres = new();

    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isSubmitting = false;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Check if user is logged in
            if (session?.CurrentUserRoleId == null || session.CurrentUserRoleId != 2 && session.CurrentUserRoleId != 1) // Ensure user is a seller or Admin
            {
                NavManager.NavigateTo("/");
                return;
            }

            // Load genres from database
            genres = await Context.Genres.ToListAsync();

            // Load listing
            listing = await ListingService.GetListingAsync(ListingId);

            // Verify ownership
            if (listing == null || listing.User_ID != session.CurrentUser.Id)
            {
                listing = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading listing: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SubmitForm()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;
            successMessage = string.Empty;

            // Validate form
            if (string.IsNullOrWhiteSpace(listing.Textbook.Title))
            {
                errorMessage = "Title is required";
                return;
            }

            if (string.IsNullOrWhiteSpace(listing.Textbook.Author))
            {
                errorMessage = "Author is required";
                return;
            }

            if (listing.Textbook.Genre_ID == 0)
            {
                errorMessage = "Please select a genre";
                return;
            }

            if (listing.Price <= 0)
            {
                errorMessage = "Price must be greater than $0.00";
                return;
            }

            if (string.IsNullOrWhiteSpace(listing.Condition))
            {
                errorMessage = "Please select a condition";
                return;
            }

            // Update Date_Updated
            listing.Date_Updated = DateTime.UtcNow;

            // Update listing via service
            await ListingService.UpdateListingAsync(listing);

            successMessage = "Listing updated successfully!";
            await Task.Delay(1500);
            NavManager.NavigateTo("/managelistings");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating listing: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        NavManager.NavigateTo("/managelistings");
    }

    private void GoBack()
    {
        NavManager.NavigateTo("/managelistings");
    }
}
